# Watch directory (WordPress root)
watch_path: /var/www/html

# Baseline storage
baseline_path: /etc/wp-guard/baseline.json

# Quarantine storage
quarantine_path: /var/www/wp-guard-quarantine

# Log file
log_path: /var/log/wp-guard/events.log
log_format: text  # text or json

# How often to check for file changes (seconds)
poll_interval_sec: 30

# Notify even when a clean file changes (update baseline silently)
notify_on_clean: false

# AI Triage - use OpenRouter or Anthropic API
ai:
  enabled: false
  provider: openrouter  # "openrouter" or "anthropic"
  model: anthropic/claude-3-haiku
  api_key: ""
  # OpenRouter:
  api_url: https://openrouter.ai/api/v1/chat/completions
  # Anthropic (optional - will use default if not set):
  # api_url: https://api.anthropic.com/v1/messages
  system_prompt: |
    You are a WordPress security analyzer. Given PHP code, respond with JSON:
    {"malicious": bool, "confidence": 0.0-1.0, "reason": "...", "recommendation": "..."}

# Auto-fix - AI-powered remediation with rollback protection
auto_fix:
  enabled: false
  plugins_only: true   # only auto-fix in plugins dir (safer)
  create_backup: true # keep backups before applying fixes
  max_retries: 2      # retry attempts on failure
  rollback_on_fail: true  # auto-rollback if health check fails
  health_check_url: https://example.com/wp-admin/admin-ajax.php?action=health_check

# Telegram notifications
telegram:
  enabled: false
  token: ""
  chat_id: ""

# Email notifications
email:
  enabled: false
  smtp_host: "smtp.gmail.com"
  smtp_port: 587
  smtp_user: ""
  smtp_pass: ""
  from: ""
  to: ""
  use_tls: true

# Slack notifications
slack:
  enabled: false
  webhook_url: ""
  channel: "#security"
  username: "wp-guard"

# Discord notifications
discord:
  enabled: false
  webhook_url: ""

# Syslog notifications
syslog:
  enabled: false
  host: "localhost"
  port: 514
  app_name: "wp-guard"

# HTTP API server
http:
  enabled: false
  addr: "0.0.0.0"
  port: 8080
  auth_token: "CHANGE_ME"

# Rate limiting - prevent alert spam
rate_limit:
  enabled: false
  window_sec: 300  # 5 minutes
  max_alerts: 5

# Hooks - run custom scripts on events
hooks:
  enabled: false
  on_critical: "/etc/wp-guard/scripts/alert-critical.sh"
  on_warn: ""
  on_clean: ""
  timeout_sec: 30

# WordPress paths
wordpress:
  core_files:
    - wp-config.php
    - wp-settings.php
    - wp-load.php
  themes_dir: wp-content/themes
  plugins_dir: wp-content/plugins

# Scanner settings
scanner:
  max_file_size_mb: 10
  exclude_extensions:
    - .jpg
    - .jpeg
    - .png
    - .gif
    - .svg
    - .ico
    - .pdf
    - .zip
    - .tar
    - .gz
    - .log
  exclude_paths:
    - wp-content/uploads
    - wp-content/cache
    - node_modules
    - .git
  # Skip patterns - paths containing these strings are ignored during scan
  skip_patterns:
    # - wordpress-seo  # auto-updating plugin
    # - jetpack
  suspicious_patterns:
    # Add custom patterns here